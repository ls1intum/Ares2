<?xml version="1.0" encoding="UTF-8"?>
<!--
	Ares SpotBugs exclusions.

	Only patterns that fire on a deliberate Ares design decision are excluded here. Everything
	else stays enforced, including the SECURITY category.
-->
<FindBugsFilter
		xmlns="https://github.com/spotbugs/filter/3.0.0"
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

	<!--
		The advice toolboxes and other utility classes forbid instantiation by throwing a
		SecurityException from their constructor, which is exactly what this pattern reports.
		Removing the throw would hand student code a way to instantiate the security machinery,
		so the pattern is a false positive against this design.
	-->
	<Match>
		<Bug pattern="CT_CONSTRUCTOR_THROW"/>
	</Match>

	<!--
		The advice catches NullPointerException on purpose and converts it into a
		SecurityException, because an argument supplied by student code may be null at any point
		the advice inspects it, and failing open there would let the operation through.
	-->
	<Match>
		<Bug pattern="DCN_NULLPOINTER_EXCEPTION"/>
	</Match>

	<!--
		Storing and returning the policy arrays without copying is intentional. The advice runs
		on every intercepted call, so a defensive copy per invocation sits directly in the hot
		path, and the arrays it holds are internal to the security machinery, which student code
		cannot reach: the architecture-analysis layer forbids student references to these classes.
		Revisit if that layer ever stops being authoritative.
	-->
	<Match>
		<Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
	</Match>

	<!--
		The advice settings in the aspects have to be public and static because
		JavaAOPTestCase.setJavaAdviceSettingValue writes them reflectively, by name, before a
		test case runs. Narrowing their visibility would break the only channel through which a
		security policy reaches the woven advice.
	-->
	<Match>
		<Package name="de.tum.cit.ase.ares.api.aop.java.aspectj.adviceandpointcut"/>
		<Bug pattern="PA_PUBLIC_PRIMITIVE_ATTRIBUTE"/>
	</Match>

	<!--
		The throwable sanitisers dispatch on the throwable's type before they cast it, so the
		cast is safe by construction. SpotBugs cannot see the dispatch, because it happens
		through the sanitiser registry rather than through an instanceof in the same method.
	-->
	<Match>
		<Package name="de.tum.cit.ase.ares.api.internal.sanitization"/>
		<Bug pattern="BC_UNCONFIRMED_CAST"/>
	</Match>

	<!--
		The advice re-checks values that its own annotations already declare non-null. That
		redundancy is deliberate: the advice inspects arguments handed to it by student code
		across a reflective boundary, where an annotation is a promise rather than a guarantee,
		and a missed null there fails open.
	-->
	<Match>
		<Package name="~de\.tum\.cit\.ase\.ares\.api\.aop\.java\..*"/>
		<Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
	</Match>

	<!--
		toTarget and parametersToTarget have no compiler-visible caller because
		JavaInstrumentationAdviceNetworkSystemToolboxTest reaches them through
		getDeclaredMethod. They are the unit-testable core of network target resolution, so
		removing them as dead code would delete what those tests exercise.
	-->
	<Match>
		<Method name="~(toTarget|parametersToTarget)"/>
		<Bug pattern="UPM_UNCALLED_PRIVATE_METHOD"/>
	</Match>

	<!--
		WalaRule and CustomDFSPathFinder walk a WALA call graph with getSuccNodes and
		getPredNodes, whose return type is Iterator<? extends CGNode>. SpotBugs cannot prove
		that such an iterator yields non-null elements, so it reports a possible null
		dereference on each traversal loop. The call-graph nodes WALA hands back are never
		null, and the loops that use the element already guard it (for example
		"if (successor != null && visited.add(successor))"), so there is no reachable
		dereference. Guarding the iterator in code does not move the finding, because the
		element, not the iterator, is what SpotBugs models as nullable.
	-->
	<Match>
		<Package name="de.tum.cit.ase.ares.api.architecture.java.wala"/>
		<Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
	</Match>

	<!--
		NodePosition.compareTo orders positions by their begin line and column only, so that
		unwanted AST nodes can be reported in source order. Equality is deliberately left as
		identity: two distinct AST nodes that start at the same position are different nodes,
		and NodePosition is never placed in a TreeSet or TreeMap where compareTo would stand in
		for equals. Adding a value-based equals consistent with the two-field ordering would
		instead make nodes at the same start position compare equal, which is wrong.
	-->
	<Match>
		<Class name="de.tum.cit.ase.ares.api.ast.model.NodePosition"/>
		<Bug pattern="EQ_COMPARETO_USE_OBJECT_EQUALS"/>
	</Match>

	<!--
		The JVM supplies its Instrumentation service to premain. Retaining that opaque JVM
		handle is required so policy configuration can install a package-specific call-site
		transformer after the restricted package becomes known; it is never returned or exposed
		to student code.
	-->
	<Match>
		<Class name="de.tum.cit.ase.ares.api.aop.java.instrumentation.JavaInstrumentationAgent"/>
		<Field name="instrumentation"/>
		<Bug pattern="EI_EXPOSE_STATIC_REP2"/>
	</Match>

	<!--
		getSettingsLock() has to return the exact same SETTINGS_LOCK instance to callers
		outside this class (I-032): the settings live as two separate copies of this class, one
		per classloader, and JavaAOPTestCase / the AspectJ and instrumentation advice toolboxes
		reach the *other* copy's lock reflectively so a write on one classloader's copy and
		reset() on the other cannot interleave. That cross-classloader coordination is only
		possible if the accessor is public, which is exactly the pattern this bug flags when
		reset() also synchronizes on the same field internally. Narrowing the accessor's
		visibility would defeat the fix it exists to support.
	-->
	<Match>
		<Class name="de.tum.cit.ase.ares.api.aop.java.JavaAOPTestCaseSettings"/>
		<Method name="reset"/>
		<Bug pattern="USO_UNSAFE_ACCESSIBLE_OBJECT_SYNCHRONIZATION"/>
	</Match>

	<!--
		This method is a transparent replacement for one Object.wait() invocation. It must call
		wait exactly once and return with the same semantics as the original call site; introducing
		a condition loop in the wrapper would change application behaviour. The caller remains
		responsible for the standard wait-condition loop.
	-->
	<Match>
		<Class name="de.tum.cit.ase.ares.api.aop.java.instrumentation.advice.JavaInstrumentationThreadSystemCallSite"/>
		<Method name="wait" signature="(Ljava/lang/Object;)V"/>
		<Bug pattern="WA_NOT_IN_LOOP"/>
	</Match>
</FindBugsFilter>
